{
  "name": "sam-ar-whatsapp-reputation",
  "version": "1.0.0",
  "description": "WhatsApp Reputation Monitor – AWS SAM Project",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "sam:build": "sam build",
    "sam:deploy:dev": "sam deploy --config-env dev",
